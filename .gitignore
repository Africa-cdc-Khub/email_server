# Dependencies / build
/vendor
/node_modules
frontend/dist
backend/.composer-cache
*.log

# Local env & secrets — NEVER commit these
.env
.env.*
!.env.example
!**/.env.example

docker/.env
backend/.env

# Production deploy secrets (copy outside the repo)
*.secrets.env
secrets.env
**/secrets.env
production.secrets.env
deploy/production.secrets.env
/etc-email-server/

# Laravel / runtime
backend/storage/logs/*
backend/storage/framework/cache/data/*
!backend/storage/logs/.gitignore
backend/bootstrap/cache/*.php
!backend/bootstrap/cache/.gitignore
