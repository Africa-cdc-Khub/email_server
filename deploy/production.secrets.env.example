# External secrets template for setup.sh — PLACEHOLDERS ONLY.
# Copy OUTSIDE the repo (or to a gitignored path), then fill real values:
#
#   sudo mkdir -p /etc/email-server
#   sudo cp deploy/production.secrets.env.example /etc/email-server/secrets.env
#   sudo chmod 600 /etc/email-server/secrets.env
#   # edit /etc/email-server/secrets.env with real secrets
#   ./setup.sh --env-file=/etc/email-server/secrets.env
#
# Never commit a filled secrets.env / production.secrets.env file.

DOMAIN=notifications.africacdc.org
ADMIN_EMAIL=andrewa@africacdc.org
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
DB_PASSWORD=CHANGE_ME_DB_PASSWORD
MYSQL_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING_AT_LEAST_64_CHARS
JWT_TTL=60
EMAIL_SERVER_DATA_PATH=/home/email_serverdata
MAIL_FROM_ADDRESS=notifications@africacdc.org
MAIL_FROM_NAME=Africa CDC Notifications
CERTBOT_EMAIL=andrewa@africacdc.org

# Microsoft Graph / Exchange
EXCHANGE_TENANT_ID=CHANGE_ME_TENANT_ID
EXCHANGE_CLIENT_ID=CHANGE_ME_CLIENT_ID
EXCHANGE_CLIENT_SECRET=CHANGE_ME_CLIENT_SECRET

# Optional — auto-generated by setup.sh if empty
INTEGRATION_CLIENT_SECRET=

# Optional deploy flags
QUEUE_SCALE=2
RUN_SEEDER=true
# SKIP_SSL=false
