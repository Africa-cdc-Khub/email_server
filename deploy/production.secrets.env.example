# Production secrets template — PLACEHOLDERS ONLY.
#
# Recommended: copy values into docker/.env and backend/.env on the server
# (setup.sh reads those files and does NOT overwrite them).
#
#   cp docker/.env.example docker/.env
#   cp backend/.env.example backend/.env
#   chmod 600 docker/.env backend/.env
#   # edit both files with real secrets
#   ./setup.sh
#
# Optional legacy path: copy to /etc/email-server/secrets.env and use
#   ./setup.sh --write-env --env-file=/etc/email-server/secrets.env
# (only on a fresh box — --write-env regenerates docker/.env + backend/.env)

DOMAIN=notifications.africacdc.org
ADMIN_EMAIL=andrewa@africacdc.org
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
DB_PASSWORD=CHANGE_ME_DB_PASSWORD
MYSQL_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING_AT_LEAST_64_CHARS
JWT_TTL=60
EMAIL_SERVER_DATA_PATH=/home/email_serverdata
MAIL_FROM_ADDRESS=notifications@africacdc.org
MAIL_FROM_NAME=Africa CDC Notifications
CERTBOT_EMAIL=andrewa@africacdc.org
API_HOST_PORT=8089
MYSQL_HOST_PORT=3309

# Microsoft Graph / Exchange
EXCHANGE_TENANT_ID=CHANGE_ME_TENANT_ID
EXCHANGE_CLIENT_ID=CHANGE_ME_CLIENT_ID
EXCHANGE_CLIENT_SECRET=CHANGE_ME_CLIENT_SECRET

# Optional — auto-generated by setup when using --write-env
INTEGRATION_CLIENT_SECRET=

# Optional deploy flags
QUEUE_SCALE=2
RUN_SEEDER=true
# SKIP_SSL=false
