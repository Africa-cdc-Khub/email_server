APP_ENV=production
APP_DEBUG=false
RUN_SEEDER=true
JWT_SECRET=change-me-to-a-long-random-string-at-least-64-chars-long-for-production
JWT_TTL=60

# Public URLs (host Nginx + TLS)
APP_URL=https://notifications.africacdc.org
FRONTEND_URL=https://notifications.africacdc.org

# Persistent data directory on the host (MySQL + Redis).
# Linux production: /home/email_serverdata
# macOS local dev:  /Users/<your-user>/email_serverdata
EMAIL_SERVER_DATA_PATH=/home/email_serverdata

ADMIN_EMAIL=andrewa@africacdc.org
ADMIN_PASSWORD=change-me-to-a-strong-password

# Required — do not use weak defaults in production
DB_PASSWORD=change-me-db-password
MYSQL_ROOT_PASSWORD=change-me-root-password
