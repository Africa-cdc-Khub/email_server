APP_NAME="Email Server"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8089

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=email_server
DB_USERNAME=email_server
DB_PASSWORD=email_server

# Queue — Redis (required for async email dispatch)
QUEUE_CONNECTION=redis
QUEUE_FAILED_DRIVER=null
REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE_DB=2
REDIS_QUEUE_CONNECTION=queue
CACHE_STORE=redis

SESSION_DRIVER=redis
SESSION_LIFETIME=120

# Default mailer — Exchange (DB providers override at send time)
MAIL_MAILER=exchange
MAIL_FROM_ADDRESS=notifications@example.com
MAIL_FROM_NAME="Email Server"

# Exchange (Microsoft Graph) — copy from staff/apm or staff/helpdesk .env
EXCHANGE_TENANT_ID=
EXCHANGE_CLIENT_ID=
EXCHANGE_CLIENT_SECRET=
EXCHANGE_REDIRECT_URI=
EXCHANGE_SCOPE=https://graph.microsoft.com/.default
EXCHANGE_AUTH_METHOD=client_credentials

# SMTP fallback (optional)
MAIL_HOST=smtp.office365.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls

# Admin panel login (seeded)
ADMIN_EMAIL=andrewa@africacdc.org
ADMIN_PASSWORD=change-me-in-production
FRONTEND_URL=http://localhost:3006

# Integration JWT credentials (seeded example: staff-portal)
INTEGRATION_CLIENT_SECRET=
JWT_SECRET=
JWT_TTL=60

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8089,localhost:3006,127.0.0.1,127.0.0.1:8089,127.0.0.1:3006
